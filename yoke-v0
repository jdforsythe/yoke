#!/usr/bin/env bash
# yoke-v0 — Phase δ bootstrap glue. See docs/runbook-addenda/yoke-v0-usage.md.
# Commands: run | continue | record | logs
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
H="python3 $SCRIPT_DIR/yoke-v0-helper.py"
CONFIG="${YOKE_V0_CONFIG:-$SCRIPT_DIR/.yoke-v0.json}"
LOG_DIR="${YOKE_LOG_DIR:-.yoke/logs}"
SESSIONS="${YOKE_LOG_DIR:-.yoke}/sessions.jsonl"

die()  { printf 'yoke-v0: error: %s\n' "$*" >&2; exit 1; }
info() { printf 'yoke-v0: %s\n'        "$*" >&2; }

usage() {
  cat >&2 <<'EOF'
yoke-v0  Phase δ bootstrap glue

  run      <phase> <feature-id>           assemble + spawn agent
  continue <phase> <feature-id>           same, resume with -c
  record   <phase> <feature-id> <label>   run and label the log (fixtures)
  logs     <session-id-prefix>            print captured stream-json log

Phases: plan | implement | review  (any prompts/<phase>.md)
Config: .yoke-v0.json  (YOKE_V0_CONFIG to override)
Env:    YOKE_CONTEXT   inject context into every prompt
EOF
  exit 1
}

ensure_dirs() {
  mkdir -p "$LOG_DIR" "$(dirname "$SESSIONS")"
  [[ -f "$SESSIONS" ]] || touch "$SESSIONS"
}

run_cmds() {
  local label="$1"; shift
  local cmd; for cmd in "$@"; do
    [[ -z "$cmd" ]] && continue
    info "$label: $cmd"
    eval "$cmd" || info "warning: $label exited non-zero (continuing)"
  done
}

do_run() {
  local phase="$1" feat="$2" label="${3:-}" use_c="${4:-}"
  ensure_dirs

  local ts; ts=$(date -u +%Y%m%dT%H%M%SZ)
  local log_path="$LOG_DIR/${ts}-${phase}-${feat}${label:+-$label}.jsonl"
  local prompt_file; prompt_file=$(mktemp /tmp/yoke-v0-XXXXXX.md)
  # shellcheck disable=SC2064
  trap "rm -f '$prompt_file'" EXIT

  info "assembling: $phase / $feat"
  local cfg_json
  cfg_json=$($H assemble "$phase" "$feat" "$CONFIG" "$prompt_file") \
    || die "prompt assembly failed"

  local cmd
  cmd=$(python3 -c "import sys,json; print(json.loads(sys.argv[1])['command'])" "$cfg_json")

  local -a args=() pre=() post=()
  while IFS= read -r a; do [[ -n "$a" ]] && args+=("$a"); done \
    < <(python3 -c "import sys,json
[print(x) for x in json.loads(sys.argv[1])['args']]" "$cfg_json")
  while IFS= read -r a; do [[ -n "$a" ]] && pre+=("$a"); done \
    < <(python3 -c "import sys,json
[print(x) for x in json.loads(sys.argv[1]).get('pre',[])]" "$cfg_json")
  while IFS= read -r a; do [[ -n "$a" ]] && post+=("$a"); done \
    < <(python3 -c "import sys,json
[print(x) for x in json.loads(sys.argv[1]).get('post',[])]" "$cfg_json")

  run_cmds "pre" ${pre[@]+"${pre[@]}"}

  local -a extra=(); [[ -n "$use_c" ]] && extra=("-c")
  info "spawning: $cmd ${args[*]-}${extra:+ ${extra[*]}}"
  info "log:      $log_path  (tail -f to watch)"

  local ec=0
  "$cmd" ${args[@]+"${args[@]}"} ${extra[@]+"${extra[@]}"} \
    < "$prompt_file" > "$log_path" 2>"${log_path%.jsonl}.err" || ec=$?
  [[ ! -s "${log_path%.jsonl}.err" ]] && rm -f "${log_path%.jsonl}.err"

  local sid; sid=$($H record "$SESSIONS" "$phase" "$feat" "$log_path" "$ec")
  [[ $ec -ne 0 ]] && info "session exited $ec — check $log_path" \
                  || info "session complete (session_id=${sid})"

  run_cmds "post" ${post[@]+"${post[@]}"}
  return $ec
}

# ── dispatch ──────────────────────────────────────────────────────────────────
subcmd="${1:-}"; shift || true
case "$subcmd" in
  run)      [[ $# -ge 2 ]] || usage; do_run "$1" "$2" ;;
  continue) [[ $# -ge 2 ]] || usage; do_run "$1" "$2" "" "1" ;;
  record)   [[ $# -ge 3 ]] || usage; do_run "$1" "$2" "$3" ;;
  logs)
    [[ $# -ge 1 ]] || usage
    matched=$($H find-log "$SESSIONS" "$1") \
      || die "no session matching '$1' in $SESSIONS"
    cat "$matched"
    ;;
  *) usage ;;
esac
