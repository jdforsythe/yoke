{
  "name": "yoke",
  "version": "0.1.0",
  "description": "Autopilot for Claude Code: run multi-stage AI pipelines defined in .yoke/templates/<name>.yml with a live web dashboard.",
  "license": "MIT",
  "author": "Jeremy Forsythe",
  "homepage": "https://github.com/jdforsythe/yoke#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdforsythe/yoke.git"
  },
  "bugs": {
    "url": "https://github.com/jdforsythe/yoke/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "agents",
    "ai",
    "pipeline",
    "harness",
    "automation",
    "cli"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/",
    "bin/yoke",
    "schemas/",
    "templates-pack/",
    "skills/yoke-setup.md",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:contract": "tsx scripts/check-api-contract.js",
    "typecheck": "tsc --noEmit && pnpm --filter web typecheck",
    "lint": "tsc --noEmit",
    "build:server": "tsc -p tsconfig.build.json && pnpm run build:assets",
    "build:assets": "mkdir -p dist/server/storage/migrations && cp src/server/storage/migrations/*.sql dist/server/storage/migrations/",
    "build:web": "pnpm --filter web build",
    "build": "pnpm run build:server && pnpm run build:web",
    "dev:web": "pnpm --filter web dev",
    "prepublishOnly": "pnpm run typecheck && pnpm run test && pnpm run build",
    "e2e": "scripts/e2e/run.sh"
  },
  "dependencies": {
    "@fastify/static": "^7.0.4",
    "@fastify/websocket": "^8.3.1",
    "@octokit/rest": "^22.0.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
    "fastify": "^4.29.1",
    "jsonpath-plus": "^10.4.0",
    "yaml": "^2.7.0"
  },
  "bin": {
    "yoke": "bin/yoke"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.17.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8",
    "ws": "^8.18.0"
  }
}
