#!/usr/bin/env bash
# Dev launcher: Yoke API server (rooted at $PWD) + Vite web dev server.
# Usage: yoke-dev [start flags...]
# Works from any directory — API uses $PWD, Vite runs from the yoke repo.
# If either server dies, the other is torn down.

set -uo pipefail

YOKE_DIR="$(cd "$(dirname "$0")/.." && pwd)"
WEB_PORT="${YOKE_WEB_PORT:-5173}"

VITE_PID=""
YOKE_PID=""

cleanup() {
  trap - EXIT INT TERM
  for pid in "$VITE_PID" "$YOKE_PID"; do
    [ -n "$pid" ] && kill -TERM "$pid" 2>/dev/null || true
  done
  # Give children a moment to exit cleanly, then SIGKILL any stragglers.
  sleep 0.3
  for pid in "$VITE_PID" "$YOKE_PID"; do
    [ -n "$pid" ] && kill -KILL "$pid" 2>/dev/null || true
  done
}
trap cleanup EXIT INT TERM

# Vite dev server (web UI). Runs from the yoke repo so pnpm --filter resolves.
( cd "$YOKE_DIR" && exec pnpm --filter web dev --port "$WEB_PORT" --strictPort ) &
VITE_PID=$!

# Browser opener: wait for Vite, then open. Short-lived; not tracked for cleanup.
(
  for _ in $(seq 1 60); do
    if curl -fs -o /dev/null "http://127.0.0.1:${WEB_PORT}/" 2>/dev/null; then
      if command -v open >/dev/null 2>&1; then
        open "http://127.0.0.1:${WEB_PORT}/"
      elif command -v xdg-open >/dev/null 2>&1; then
        xdg-open "http://127.0.0.1:${WEB_PORT}/" >/dev/null 2>&1 || true
      fi
      exit 0
    fi
    sleep 0.5
  done
) &

# API server, rooted at the user's cwd. Backgrounded so we can monitor both.
"$YOKE_DIR/bin/yoke" start "$@" &
YOKE_PID=$!

# Watch both children. If either exits, the trap cleans up the other.
# Portable across bash 3.2 (macOS default) and newer — no `wait -n`.
while kill -0 "$VITE_PID" 2>/dev/null && kill -0 "$YOKE_PID" 2>/dev/null; do
  sleep 0.5
done

# Capture whichever exited first so we can propagate its status.
if ! kill -0 "$YOKE_PID" 2>/dev/null; then
  wait "$YOKE_PID"
  exit $?
else
  wait "$VITE_PID"
  exit $?
fi
